# Copy this file to `.env` and fill in your values.
# `.devcontainer/.env` is gitignored — never commit real secrets.

# GitHub personal access token used by the `gh` CLI and for git over HTTPS
# inside the devcontainer. Also read by scripts/bootstrap.sh as a fallback when
# downloading the sofabgen release (the sofa-buffers repos are public, so this
# is optional).
GITHUB_TOKEN=
