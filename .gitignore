# Vendored corelibs + tooling (populated by scripts/bootstrap.sh)
/vendor/
/tools/sofabgen

# Per-driver build + generated code
/drivers/*/build/
/drivers/*/gen/
/drivers/*/fuzz-gen/
/drivers/go/message/
/drivers/go/go.sum

# Fuzzing artifacts
/corpus/interesting/*
/corpus/crashes/*
!/corpus/interesting/.gitkeep
!/corpus/crashes/.gitkeep

# Go native-fuzz corpus cache
testdata/fuzz/

.env

# Python bytecode cache
__pycache__/
