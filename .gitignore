# Vendored corelibs + tooling (populated by scripts/bootstrap.sh)
/vendor/
/tools/sofabgen

# Per-driver build + generated code
/drivers/*/build/
/drivers/*/gen/
/drivers/*/fuzz-gen/
/drivers/go/message/
/drivers/go/go.sum

# Fuzzing artifacts
/corpus/interesting/*
/corpus/crashes/*
!/corpus/interesting/.gitkeep
!/corpus/crashes/.gitkeep
# libFuzzer per-job logs (fuzz.sh with -jobs writes these to the repo root)
/fuzz-*.log
# Coredumps from a crashing driver/pacemaker
/core
core.*

# Go native-fuzz corpus cache
testdata/fuzz/

.env

# Python bytecode cache
__pycache__/
